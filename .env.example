# For Ollama (local, free) — this value is required by the client but Ollama ignores it
OPENAI_API_KEY=ollama

# For OpenAI — replace with your real key from platform.openai.com
# OPENAI_API_KEY=sk-your-key-here

# For Google Gemini free tier — get key from aistudio.google.com
# OPENAI_API_KEY=your-gemini-key-here
